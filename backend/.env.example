# 应用基础配置：服务名、运行环境、监听地址与 API 前缀
APP_NAME=ReguRAG Backend
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
APP_DEBUG=true
API_V1_PREFIX=/api/v1
# 存储与数据路径配置：数据库、向量库、本地数据目录和上传目录
DATABASE_URL=mysql+pymysql://root:123456@127.0.0.1:3306/regurag?charset=utf8mb4
# PostgreSQL 预备写法示例：DATABASE_URL=postgresql+psycopg://regurag:regurag123@127.0.0.1:5432/regurag
CHROMA_PATH=./chroma_db
DATA_DIR=./data
UPLOADS_DIR=./data/uploads
# 跨域配置：前端开发地址与 CORS 开关
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*
# 主生成模型配置：回答阶段使用的 OpenAI 兼容模型参数
OPENAI_API_KEY=replace-me
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=45
OPENAI_MAX_TOKENS=1200
# 改写模型配置：查询改写与多轮问题补全使用的模型参数
REWRITE_API_KEY=replace-me
REWRITE_BASE_URL=https://api.openai.com/v1
REWRITE_MODEL=gpt-4.1-mini
# 入口意图本地分类器：默认启用；未单独指定时会复用 embedding 模型
INTENT_LOCAL_CLASSIFIER_ENABLED=true
INTENT_LOCAL_CLASSIFIER_MODEL=
INTENT_LOCAL_CLASSIFIER_ARTIFACT_PATH=./data/models/intent_classifier.pt
INTENT_LOCAL_CLASSIFIER_MIN_SCORE=0.55
INTENT_LOCAL_CLASSIFIER_MIN_MARGIN=0.03
# 入口意图云端分类器：仅作为本地分类器无法判定时的可选兜底；未单独指定时会回退到 rewrite 模型配置
INTENT_LLM_CLASSIFIER_ENABLED=false
INTENT_LLM_CLASSIFIER_API_KEY=
INTENT_LLM_CLASSIFIER_BASE_URL=
INTENT_LLM_CLASSIFIER_MODEL=
INTENT_LLM_CLASSIFIER_TIMEOUT_SECONDS=15
INTENT_LLM_CLASSIFIER_MAX_TOKENS=64
# 检索模型配置：Embedding、Reranker 与 Chroma 集合名
EMBEDDING_MODEL_NAME=BAAI/bge-small-zh-v1.5
RERANKER_MODEL_NAME=BAAI/bge-reranker-base
CHROMA_COLLECTION_NAME=regurag_docs
CONFIG_PROFILE=rules_cn
# 默认知识库配置：系统启动时可自动导入的知识库主题与源文档
KNOWLEDGE_BASE_SUBJECT=通用知识主题
SOURCE_DOCUMENT_PATH=
DEFAULT_KNOWLEDGE_BASE_ID=kb_001
DEFAULT_KNOWLEDGE_BASE_NAME=默认知识库
DEFAULT_KNOWLEDGE_BASE_DESCRIPTION=系统启动时自动导入的默认知识库
DEFAULT_KNOWLEDGE_BASE_DOMAIN=general
# 检索链路参数：切块大小与 MMR 选择数量
CHILD_CHUNK_SIZE=50
TOP_K_MMR=8
# shadow compare 灰度配置：服务端是否自动双跑旧 pipeline 与 shadow graph，以及采样比例
CHAT_SHADOW_COMPARE_ENABLED=false
CHAT_SHADOW_COMPARE_SAMPLE_RATE=0.0
# 任务 worker 配置：数据库轮询间隔、任务租约时长与最大领取次数
TASK_WORKER_POLL_INTERVAL_SECONDS=2.0
TASK_WORKER_LEASE_SECONDS=1800
TASK_WORKER_MAX_ATTEMPTS=3
# 任务监控配置：观察窗口、长时间运行阈值、失败/重试告警阈值
TASK_MONITOR_WINDOW_HOURS=24
TASK_MONITOR_LONG_RUNNING_SECONDS=3600
TASK_MONITOR_RECENT_FAILURE_THRESHOLD=3
TASK_MONITOR_RECENT_RETRY_THRESHOLD=5
# 日志配置
LOG_LEVEL=INFO
